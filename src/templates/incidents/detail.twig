{% extends '_layouts/cp' %}

{% set selectedSubnavItem = 'incidents' %}

{% set crumbs = [
	{ html: "<a href='" ~ url('upsnap') ~ "' class='thumb cp-icon'><svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 576 512' focusable='false' aria-hidden='true'><path d='M575.8 255.5c0 18-15 32.1-32 32.1l-32 0 .7 160.2c0 2.7-.2 5.4-.5 8.1l0 16.2c0 22.1-17.9 40-40 40l-16 0c-1.1 0-2.2 0-3.3-.1c-1.4 .1-2.8 .1-4.2 .1L416 512l-24 0c-22.1 0-40-17.9-40-40l0-24 0-64c0-17.7-14.3-32-32-32l-64 0c-17.7 0-32 14.3-32 32l0 64 0 24c0 22.1-17.9 40-40 40l-24 0-31.9 0c-1.5 0-3-.1-4.5-.2c-1.2 .1-2.4 .2-3.6 .2l-16 0c-22.1 0-40-17.9-40-40l0-112c0-.9 0-1.9 .1-2.8l0-69.7-32 0c-18 0-32-14-32-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 2 21 7L564.8 231.5c8 7 12 15 11 24z'></path></svg></a>" },
	{ label: 'Incidents'|t('upsnap'), url: cpIncidentsUrl },
] %}
{% set _logoBaseUrl = craft.app.assetManager.getPublishedUrl('@upsnapRoot/assets/images/logo', true) %}


{% block content %}
	<script>
		window.UpsnapIncidentDetail = {
            logoBaseUrl: {{ (_logoBaseUrl ?? '')|json_encode|raw }},
			incidentId:          {{ incidentId|json_encode|raw }},
			monitorId:           {{ monitorId|json_encode|raw }},
			detailEndpoint:      {{ detailEndpoint|json_encode|raw }},
			regionsEndpoint:     {{ regionsEndpoint|json_encode|raw }},
			cpIncidentsUrl:      {{ cpIncidentsUrl|json_encode|raw }},
			monitorDetailBaseUrl:{{ monitorDetailBaseUrl|json_encode|raw }},
		};
	</script>

	<div id="incident-detail-root" class="incident-detail-root">
		<div id="incident-detail-loading" class="incident-detail-loading" aria-live="polite" aria-label="{{ 'Loading…'|t('upsnap') }}">
			<div class="incident-detail-spinner"></div>
		</div>

		<div id="incident-detail-error" class="incident-detail-error" hidden>
			<p id="incident-detail-error-msg"></p>
		</div>

		<div id="incident-detail-content" hidden>
			<div id="incident-detail-header" class="incident-detail-header"></div>

			<div class="incident-detail-grid">
				<div class="incident-detail-grid__main">
					<div id="incident-detail-overview" class="incident-detail-card"></div>
					<div id="incident-detail-suggested-actions" class="incident-detail-card"></div>
					<div id="incident-detail-ai-summary" class="incident-detail-card"></div>
					<div id="incident-detail-http-headers" class="incident-detail-card"></div>
				</div>
				<div class="incident-detail-grid__side">
					<div id="incident-detail-timeline" class="incident-detail-card"></div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
