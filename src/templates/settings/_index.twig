{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% set crumbs = [
    { html: "<a href='" ~ url('upsnap') ~ "' class='thumb cp-icon'><svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 576 512' focusable='false' aria-hidden='true'><path d='M575.8 255.5c0 18-15 32.1-32 32.1l-32 0 .7 160.2c0 2.7-.2 5.4-.5 8.1l0 16.2c0 22.1-17.9 40-40 40l-16 0c-1.1 0-2.2 0-3.3-.1c-1.4 .1-2.8 .1-4.2 .1L416 512l-24 0c-22.1 0-40-17.9-40-40l0-24 0-64c0-17.7-14.3-32-32-32l-64 0c-17.7 0-32 14.3-32 32l0 64 0 24c0 22.1-17.9 40-40 40l-24 0-31.9 0c-1.5 0-3-.1-4.5-.2c-1.2 .1-2.4 .2-3.6 .2l-16 0c-22.1 0-40-17.9-40-40l0-112c0-.9 0-1.9 .1-2.8l0-69.7-32 0c-18 0-32-14-32-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 2 21 7L564.8 231.5c8 7 12 15 11 24z'></path></svg></a>" }
] %}

{% set showHealthchecks = showHealthchecks ?? false %}
{% set isActiveApiToken = apiTokenStatus is same as(apiTokenStatuses.active) ? true : false %}

{% if showHealthchecks %}
	{% set tabs = [
		{ label: "Monitors"|t('upsnap'), url: '#monitors-tab', class: 'sel' },
		(isActiveApiToken)
			? { label: "Notification Channels"|t('upsnap'), url: '#notification-channels-tab' }
			: { label: "Notification Channels"|t('upsnap'), url: '#notification-channels-tab', class: 'disabled-tab' },
		{ label: "API Key"|t('upsnap'), url: '#api-tab' }
	] %}
{% else %}
	{% set tabs = [
		{ label: "Monitors"|t('upsnap'), url: '#monitors-tab' },
		{ label: "API Key"|t('upsnap'), url: '#api-tab', class: 'sel' }
	] %}
{% endif %}


{% block actionButton %}
	<div class="flex smallgap">
		<button id="save-button" type="submit" form="settings-form" class="btn submit"{{ not showHealthchecks ? ' style="display:none;"' : '' }}>
			{{ "Save"|t('upsnap') }}
		</button>
	</div>
{% endblock %}
{% set apiTokenStatus = apiTokenStatus ?? 'expired' %}

{% set statusColorMap = {
    (apiTokenStatuses['active']): 'pill--green',
    (apiTokenStatuses['expired']): 'pill--red',
    (apiTokenStatuses['deleted']): 'pill--grey',
    (apiTokenStatuses['suspended']): 'pill--yellow'
} %}

{% set statusColorClass = statusColorMap[apiTokenStatus]|default('pill--grey') %}


{% set _logoBaseUrl = craft.app.assetManager.getPublishedUrl('@upsnapRoot/assets/images/logo', true) %}

{% block content %}
	{# inject server values for JS to consume - put this before monitor.js is loaded #}
	<script>
		window.Upsnap = window.Upsnap || {};
		window.Upsnap.settings = {
		monitoringUrl: {{ (settings.monitoringUrl ?? '')|json_encode|raw }},
			apiKey: {{ (showHealthchecks ?? '')|json_encode|raw }},
			isActiveApiToken: {{ (isActiveApiToken ?? '')|json_encode|raw }},
			apiTokenStatus: {{ (apiTokenStatus ?? 'unknown')|json_encode|raw }},
			apiTokenStatuses: {{ (apiTokenStatuses ?? 'unknown')|json_encode|raw }},
			userDetails: {{ userDetails|json_encode|raw }},
			subscriptionTypes : {{subscriptionTypes|json_encode|raw }},
			logoBaseUrl: {{ (_logoBaseUrl ?? '')|json_encode|raw }},
			signupI18n: {
				emailRequired:        {{ 'Email is required.'|t('upsnap')|json_encode|raw }},
				emailInvalid:         {{ 'Please enter a valid email address.'|t('upsnap')|json_encode|raw }},
				passwordRequired:     {{ 'Password is required.'|t('upsnap')|json_encode|raw }},
				passwordWeak:         {{ 'Password must be at least 8 characters and contain uppercase, lowercase, a number, and a special character.'|t('upsnap')|json_encode|raw }},
				creatingAccount:      {{ 'Creating account…'|t('upsnap')|json_encode|raw }},
				accountCreated:       {{ 'Account created!'|t('upsnap')|json_encode|raw }},
				successMessage:       {{ 'Account created successfully! Monitoring has started.'|t('upsnap')|json_encode|raw }},
				submitLabel:          {{ 'Start beta free trial'|t('upsnap')|json_encode|raw }},
				genericError:         {{ 'An error occurred. Please try again.'|t('upsnap')|json_encode|raw }},
				unexpectedError:      {{ 'An unexpected error occurred. Please try again.'|t('upsnap')|json_encode|raw }}
			}
		};
	</script>
		<div id="status-container-wrapper" data-page="reachability"></div>

		{# ====================== GENERAL TAB ====================== #}
		<div id="monitors-tab" class="tab-content{{ not showHealthchecks ? ' hidden' : '' }}">
			{% if not showHealthchecks %}
				<div class="status-container warning" style="margin-bottom: 24px;">
					<div class="status-header">
						<div class="status-icon warning">!</div>
						<h3 class="status-title">{{ 'Unlock Full Monitoring Insights'|t('upsnap') }}</h3>
					</div>
					<p class="status-message-dashboard">
						<a href="{{ upsnapDashboardUrl }}/signup" class="status-link" target="_blank" rel="noopener">{{ 'Register'|t('upsnap') }}</a>
						{{ ' to add monitors and unlock full monitoring insights.'|t('upsnap') }}
					</p>
				</div>
			{% endif %}
		 	{% include "upsnap/_components/monitorsTable.twig" %}
			<input type="hidden" id="monitorId" name="monitorId" value="{{ settings.monitorId ?? '' }}">
			<input type="hidden" id="monitoringUrlInput" name="monitoringUrlInput" value="{{ settings.monitoringUrl ?? '' }}">
		</div>
		{% if isActiveApiToken ?? false %}
			{% include "upsnap/_components/notificationChannels.twig" %}
		{% endif %}
		<form id="settings-form" method="post" accept-charset="UTF-8" enctype="multipart/form-data">
			{{ csrfInput() }}
			{{ actionInput('upsnap/settings/save', { id: 'form-action-input' }) }}
			{{ redirectInput('upsnap/settings') }}
			<div id="api-tab" class="tab-content{{ showHealthchecks ? ' hidden' : '' }}">
				{% if not showHealthchecks %}
					{# ── Signup form (shown when no API key is stored) ── #}
					<div id="signup-form-wrapper">
						<div class="field">
							<div class="heading">
								<label for="signup-email">{{ "Email"|t('upsnap') }}</label>
							</div>
							<div class="input ltr">
								<input type="email" id="signup-email" class="text fullwidth" placeholder="you@example.com" autocomplete="email">
							</div>
							<p id="signup-email-error" class="error" style="display:none;"></p>
						</div>
						<div class="field">
							<div class="heading">
								<label for="signup-password">{{ "Password"|t('upsnap') }}</label>
							</div>
							<div class="input ltr">
								<input type="password" id="signup-password" class="text fullwidth" autocomplete="new-password">
							</div>
							<p id="signup-password-error" class="error" style="display:none;"></p>
							<p class="instructions">{{ "Must be at least 8 characters with uppercase, lowercase, a number, and a special character."|t('upsnap') }}</p>
						</div>
						<div style="margin-top: 20px;">
							<button id="signup-submit-btn" type="button" class="btn submit">
								{{ "Start beta free trial"|t('upsnap') }}
							</button>
						</div>
						<p id="signup-general-error" class="error" style="display:none; margin-top: 8px;"></p>
						<p class="light" style="margin-top: 16px;">
							{{ "Already have an account?"|t('upsnap') }}
							<a id="toggle-api-key-form" href="#">{{ "Enter your API key"|t('upsnap') }}</a>
						</p>
					</div>

					{# ── Existing API key form (revealed via "Already have an account?" toggle) ── #}
					<div id="existing-api-key-wrapper" style="display:none;">
						{{ forms.textField({
							label: "API Key"|t('upsnap'),
							instructions: "Enter the Upsnap API Key and save to enable Healthcheck settings. To access the API key, please visit the <a href='#{upsnapDashboardUrl}' target='_blank' rel='noopener noreferrer'>Upsnap Dashboard<span class='sr-only' style='position:absolute;left:-10000px;'> (opens in a new tab)</span></a>"|t('upsnap')|raw,
							id: 'apiKey',
							name: 'apiKey',
							type: 'text',
							value: settings.apiKey ?? '',
							placeholder: 'XXXX-XXXX-XXXX-XXXX',
							errors: settings.getErrors('apiKey') ?? false
						}) }}
						<p class="light" style="margin-top: 16px;">
							{{ "Don't have an API key?"|t('upsnap') }}
							<a id="toggle-register-form" href="#">{{ "Register for free"|t('upsnap') }}</a>
						</p>
					</div>
				{% else %}
					{# ── API key already stored – show masked key with status badge ── #}
					<div class="api-key-field-with-status">
						{{ forms.textField({
							label: "API Key"|t('upsnap'),
							instructions: "Enter the Upsnap API Key and save to enable Healthcheck settings. To access the API key, please visit the <a href='#{upsnapDashboardUrl}' target='_blank' rel='noopener noreferrer'>Upsnap Dashboard<span class='sr-only' style='position:absolute;left:-10000px;'> (opens in a new tab)</span></a>"|t('upsnap')|raw,
							id: 'apiKey',
							name: 'apiKey',
							type: 'text',
							value: settings.apiKey ?? '',
							placeholder: 'XXXX-XXXX-XXXX-XXXX',
							errors: settings.getErrors('apiKey') ?? false
						}) }}
						<span class="api-pill {{ statusColorClass }}">
							{{ apiTokenStatus|capitalize }}
						</span>
					</div>
				{% endif %}
			</div>
		</form>

{% endblock %}

{% block foot %}
	<script>
		window.CraftPageData = {
			title: {{ title|json_encode|raw }},
			monitorUrl: {{ settings.monitoringUrl|json_encode|raw }}
		};
	</script>
{% endblock %}
