{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% set crumbs = [
    { html: "<a href='" ~ url('upsnap') ~ "' class='thumb cp-icon'><svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 576 512' focusable='false' aria-hidden='true'><path d='M575.8 255.5c0 18-15 32.1-32 32.1l-32 0 .7 160.2c0 2.7-.2 5.4-.5 8.1l0 16.2c0 22.1-17.9 40-40 40l-16 0c-1.1 0-2.2 0-3.3-.1c-1.4 .1-2.8 .1-4.2 .1L416 512l-24 0c-22.1 0-40-17.9-40-40l0-24 0-64c0-17.7-14.3-32-32-32l-64 0c-17.7 0-32 14.3-32 32l0 64 0 24c0 22.1-17.9 40-40 40l-24 0-31.9 0c-1.5 0-3-.1-4.5-.2c-1.2 .1-2.4 .2-3.6 .2l-16 0c-22.1 0-40-17.9-40-40l0-112c0-.9 0-1.9 .1-2.8l0-69.7-32 0c-18 0-32-14-32-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 2 21 7L564.8 231.5c8 7 12 15 11 24z'></path></svg></a>" }
] %}

{% set showHealthchecks = showHealthchecks ?? false %}
{% set isActiveApiToken = apiTokenStatus is same as(apiTokenStatuses.active) ? true : false %}

{% if showHealthchecks %}
	{% set tabs = [
		{ label: "Monitors"|t('upsnap'), url: '#monitors-tab', class: 'sel' },
		(isActiveApiToken)
			? { label: "Notification Channels"|t('upsnap'), url: '#notification-channels-tab' }
			: { label: "Notification Channels"|t('upsnap'), url: '#notification-channels-tab', class: 'disabled-tab' },
		{ label: "API Key"|t('upsnap'), url: '#api-tab' }
	] %}
{% else %}
	{% set tabs = [
		{ label: "Register/Sign In"|t('upsnap'), url: '#register-signin-tab', class: 'sel' }
	] %}
{% endif %}


{% block actionButton %}
	<div class="flex smallgap">
		<button id="save-button" type="submit" form="settings-form" class="btn submit"{{ not showHealthchecks ? ' style="display:none;"' : '' }}>
			{{ "Save"|t('upsnap') }}
		</button>
	</div>
{% endblock %}
{% set apiTokenStatus = apiTokenStatus ?? apiTokenStatuses.deleted %}

{% set statusColorMap = {
    (apiTokenStatuses['active']): 'pill--green',
    (apiTokenStatuses['expired']): 'pill--red',
    (apiTokenStatuses['account_expired']): 'pill--red',
    (apiTokenStatuses['deleted']): 'pill--grey',
    (apiTokenStatuses['suspended']): 'pill--yellow'
} %}

{% set statusColorClass = statusColorMap[apiTokenStatus]|default('pill--grey') %}


{% set _logoBaseUrl = craft.app.assetManager.getPublishedUrl('@upsnapRoot/assets/images/logo', true) %}

{% block content %}
	{# inject server values for JS to consume - put this before monitor.js is loaded #}
	<script>
		window.Upsnap = window.Upsnap || {};
		window.Upsnap.settings = {
		monitoringUrl: {{ (settings.monitoringUrl ?? '')|json_encode|raw }},
			apiKey: {{ (showHealthchecks ?? '')|json_encode|raw }},
			isActiveApiToken: {{ (isActiveApiToken ?? '')|json_encode|raw }},
			apiTokenStatus: {{ (apiTokenStatus ?? 'unknown')|json_encode|raw }},
			apiTokenStatuses: {{ (apiTokenStatuses ?? 'unknown')|json_encode|raw }},
			userDetails: {{ userDetails|json_encode|raw }},
			subscriptionTypes : {{subscriptionTypes|json_encode|raw }},
			logoBaseUrl: {{ (_logoBaseUrl ?? '')|json_encode|raw }},
			signupI18n: {
				emailRequired:        {{ 'Email is required.'|t('upsnap')|json_encode|raw }},
				emailInvalid:         {{ 'Please enter a valid email address.'|t('upsnap')|json_encode|raw }},
				passwordRequired:     {{ 'Password is required.'|t('upsnap')|json_encode|raw }},
				passwordWeak:         {{ 'Password must be at least 8 characters and contain uppercase, lowercase, a number, and a special character.'|t('upsnap')|json_encode|raw }},
				confirmPasswordRequired: {{ 'Confirm password is required.'|t('upsnap')|json_encode|raw }},
				passwordMismatch:     {{ 'Passwords do not match.'|t('upsnap')|json_encode|raw }},
				fullNameRequired:     {{ 'Full name is required.'|t('upsnap')|json_encode|raw }},
				creatingAccount:      {{ 'Creating account…'|t('upsnap')|json_encode|raw }},
				accountCreated:       {{ 'Account created!'|t('upsnap')|json_encode|raw }},
				successMessage:       {{ 'Account created successfully! Monitoring has started.'|t('upsnap')|json_encode|raw }},
				submitLabel:          {{ 'Start Monitoring'|t('upsnap')|json_encode|raw }},
				genericError:         {{ 'An error occurred. Please try again.'|t('upsnap')|json_encode|raw }},
				unexpectedError:      {{ 'An unexpected error occurred. Please try again.'|t('upsnap')|json_encode|raw }},
				loginSuccess:         {{ 'Login successful!'|t('upsnap')|json_encode|raw }},
				loginError:           {{ 'Login failed. Please check your credentials and try again.'|t('upsnap')|json_encode|raw }},
				creatingFirstMonitor: {{ 'No monitors found. Creating your first monitor...'|t('upsnap')|json_encode|raw }},
				primaryMonitorPlaceholder: {{ 'Select a monitor'|t('upsnap')|json_encode|raw }},
				primaryMonitorRequired: {{ 'Please select a primary monitor.'|t('upsnap')|json_encode|raw }},
				primaryMonitorSaveFailed: {{ 'Failed to save primary monitor.'|t('upsnap')|json_encode|raw }},
				primaryMonitorSaved: {{ 'Primary monitor updated.'|t('upsnap')|json_encode|raw }},
				signInLabel:          {{ 'Sign In'|t('upsnap')|json_encode|raw }},
				signUpLabel:          {{ 'Sign Up'|t('upsnap')|json_encode|raw }}
			}
		};
	</script>
		<div id="status-container-wrapper" data-page="reachability"></div>

		{# Expired Account Banner #}
		{% if apiTokenStatus == apiTokenStatuses.account_expired %}
			<div class="status-container error" style="margin-bottom: 24px;">
				<div class="status-header">
					<div class="status-icon error">!</div>
					<h3 class="status-title">{{ 'Account Expired'|t('upsnap') }}</h3>
				</div>
			<p class="status-message-dashboard">
				{% set forgotPasswordLink %}
					<a href="{{ upsnapDashboardUrl }}/reset-password" target="_blank" rel="noopener noreferrer">
						{{ 'forgot-password'|t('upsnap') }}
					</a>
				{% endset %}

				{{ 'Your 3-day free trial has expired. Please verify your email to continue using the service. Check your inbox for the verification link sent at registration, or use the {link} flow to verify your account.' 
					| t('upsnap', { link: forgotPasswordLink }) | raw }}
				<br><br>
			</p>
			</div>
		{% elseif apiTokenStatus == apiTokenStatuses.expired %}
			<div class="status-container error" style="margin-bottom: 24px;">
				<div class="status-header">
					<div class="status-icon error">!</div>
					<h3 class="status-title">{{ 'API Token Expired'|t('upsnap') }}</h3>
				</div>
				<p class="status-message-dashboard">
					{% set dashboardLink %}
						<a href="{{ upsnapDashboardUrl }}" target="_blank" rel="noopener noreferrer">
							{{ 'dashboard'|t('upsnap') }}
						</a>
					{% endset %}

					{{ 'Your API token has expired. Please generate a new token in the Upsnap Dashboard and update it here to continue using monitoring features. You can also use the {link} to recover access.' 
						| t('upsnap', { link: dashboardLink }) | raw }}
					<br><br>
				</p>
			</div>
		{% endif %}

		{# ====================== GENERAL TAB ====================== #}
		<div id="monitors-tab" class="tab-content{{ not showHealthchecks ? ' hidden' : '' }}">
			{% if not showHealthchecks %}
				<div class="status-container warning" style="margin-bottom: 24px;">
					<div class="status-header">
						<div class="status-icon warning">!</div>
						<h3 class="status-title">{{ 'Unlock Full Monitoring Insights'|t('upsnap') }}</h3>
					</div>
					<p class="status-message-dashboard">
						<a href="{{ upsnapDashboardUrl }}/signup" class="status-link" target="_blank" rel="noopener">{{ 'Register'|t('upsnap') }}</a>
						{{ ' to add monitors and unlock full monitoring insights.'|t('upsnap') }}
					</p>
				</div>
			{% endif %}
		 	{% include "upsnap/_components/monitorsTable.twig" %}
			<input type="hidden" id="monitorId" name="monitorId" value="{{ settings.monitorId ?? '' }}">
			<input type="hidden" id="monitoringUrlInput" name="monitoringUrlInput" value="{{ settings.monitoringUrl ?? '' }}">
		</div>

		{# ====================== REGISTER/SIGN IN TAB ====================== #}
		<div id="register-signin-tab" class="tab-content{{ showHealthchecks ? ' hidden' : '' }}">
			<div class="status-container" style="margin-bottom: 24px;">
				<p class="status-message-dashboard">
					{{ 'Register or sign in to start monitoring your site and unlock full monitoring insights.'|t('upsnap') }}
				</p>
			</div>
			{# ── Signup form ── #}
			<div id="signup-form-wrapper">
				<div class="field">
					<div class="heading">
						<label for="signup-fullname">{{ "Full Name"|t('upsnap') }}</label>
					</div>
					<div class="input ltr">
						<input type="text" id="signup-fullname" class="text fullwidth" placeholder="John Doe" autocomplete="name">
					</div>
					<p id="signup-fullname-error" class="error" style="display:none;"></p>
				</div>
				<div class="field">
					<div class="heading">
						<label for="signup-email">{{ "Email"|t('upsnap') }}</label>
					</div>
					<div class="input ltr">
						<input type="email" id="signup-email" class="text fullwidth" placeholder="you@example.com" autocomplete="email">
					</div>
					<p id="signup-email-error" class="error" style="display:none;"></p>
				</div>
				<div class="field">
					<div class="heading">
						<label for="signup-password">{{ "Password"|t('upsnap') }}</label>
					</div>
					<div class="input ltr">
						<input type="password" id="signup-password" class="text fullwidth" autocomplete="new-password">
					</div>
					<p id="signup-password-error" class="error" style="display:none;"></p>
					<p class="instructions">{{ "Must be at least 8 characters with uppercase, lowercase, a number, and a special character."|t('upsnap') }}</p>
				</div>
				<div class="field">
					<div class="heading">
						<label for="signup-confirm-password">{{ "Confirm Password"|t('upsnap') }}</label>
					</div>
					<div class="input ltr">
						<input type="password" id="signup-confirm-password" class="text fullwidth" autocomplete="new-password">
					</div>
					<p id="signup-confirm-password-error" class="error" style="display:none;"></p>
				</div>
				<div style="margin-top: 20px;">
					<button id="signup-submit-btn" type="button" class="btn submit">
						{{ "Start Monitoring"|t('upsnap') }}
					</button>
				</div>
				<p id="signup-general-error" class="error" style="display:none; text-transform: capitalize; margin-top: 8px;"></p>
				<p class="light" style="margin-top: 16px;">
					{{ "Already have an account?"|t('upsnap') }}
					<a id="toggle-signin-form" href="#">{{ "Sign in"|t('upsnap') }}</a>
				</p>
			</div>

			{# ── Signin form ── #}
			<div id="signin-form-wrapper" style="display:none;">
				<div class="field">
					<div class="heading">
						<label for="signin-email">{{ "Email"|t('upsnap') }}</label>
					</div>
					<div class="input ltr">
						<input type="email" id="signin-email" class="text fullwidth" placeholder="you@example.com" autocomplete="email">
					</div>
					<p id="signin-email-error" class="error" style="display:none;"></p>
				</div>
				<div class="field">
					<div class="heading">
						<label for="signin-password">{{ "Password"|t('upsnap') }}</label>
					</div>
					<div class="input ltr">
						<input type="password" id="signin-password" class="text fullwidth" autocomplete="current-password">
					</div>
					<p id="signin-password-error" class="error" style="display:none;"></p>
				</div>
				<div style="margin-top: 20px;">
					<button id="signin-submit-btn" type="button" class="btn submit">
						{{ "Sign In"|t('upsnap') }}
					</button>
				</div>
				<p id="signin-general-error" class="error" style="display:none; text-transform: capitalize; margin-top: 8px;"></p>
				<p class="light" style="margin-top: 16px;">
					{{ "Don't have an account?"|t('upsnap') }}
					<a id="toggle-signup-form" href="#">{{ "Sign up"|t('upsnap') }}</a>
				</p>
			</div>
		</div>

		<div id="primary-monitor-required-modal" class="upsnap-modal hidden" role="dialog" aria-modal="true" aria-labelledby="primary-monitor-modal-title">
			<div class="upsnap-modal__overlay"></div>
			<div class="upsnap-modal__container">
				<div class="upsnap-modal__header">
					<h2 id="primary-monitor-modal-title" class="upsnap-modal__title">{{ 'Select Primary Monitor'|t('upsnap') }}</h2>
				</div>
				<div class="upsnap-modal__body">
					<p class="upsnap-modal__description">{{ 'Choose a primary monitor to continue. This is required to load your dashboard data.'|t('upsnap') }}</p>
					<div class="field">
						<div class="heading">
							<label class="required" for="primary-monitor-select">{{ 'Primary Monitor'|t('upsnap') }}</label>
						</div>
						<div class="input ltr">
							<select id="primary-monitor-select" class="text fullwidth">
								<option value="">{{ 'Select a monitor'|t('upsnap') }}</option>
							</select>
						</div>
						<p id="primary-monitor-error" class="error" style="display:none; margin-top: 8px;"></p>
					</div>
				</div>
				<div class="upsnap-modal__footer">
					<button type="button" id="primary-monitor-save-btn" class="btn submit" disabled>
						{{ 'Save Primary Monitor'|t('upsnap') }}
					</button>
				</div>
			</div>
		</div>
		{% if isActiveApiToken ?? false %}
			{% include "upsnap/_components/notificationChannels.twig" %}
		{% endif %}
		<form id="settings-form" method="post" accept-charset="UTF-8" enctype="multipart/form-data">
			{{ csrfInput() }}
			{{ actionInput('upsnap/settings/save', { id: 'form-action-input' }) }}
			{{ redirectInput('upsnap/settings') }}
			<div id="api-tab" class="tab-content hidden">
				{# ── API key field ── #}
				<div class="api-key-field-with-status">
					{{ forms.textField({
						label: "API Key"|t('upsnap'),
						instructions: "Enter the Upsnap API Key and save to enable Healthcheck settings. To access the API key, please visit the <a href='#{upsnapDashboardUrl}' target='_blank' rel='noopener noreferrer'>Upsnap Dashboard<span class='sr-only' style='position:absolute;left:-10000px;'> (opens in a new tab)</span></a>"|t('upsnap')|raw,
						id: 'apiKey',
						name: 'apiKey',
						type: 'text',
						value: settings.apiKey ?? '',
						placeholder: 'XXXX-XXXX-XXXX-XXXX',
						errors: settings.getErrors('apiKey') ?? false
					}) }}
					{% if showHealthchecks %}
						<span class="api-pill {{ statusColorClass }}">
							{{ apiTokenStatus|replace({'_': ' '})|title }}
						</span>
					{% endif %}
				</div>
			</div>
		</form>

{% endblock %}

{% block foot %}
	<script>
		window.CraftPageData = {
			title: {{ title|json_encode|raw }},
			monitorUrl: {{ settings.monitoringUrl|json_encode|raw }}
		};

		// Initialize signup inline progress component
		document.addEventListener('DOMContentLoaded', function() {
			if (typeof window.UpsnapSignupProgress !== 'undefined') {
				window.UpsnapSignupProgress.init();
			}

			// Initialize verification banner
			if (typeof window.UpsnapVerificationBanner !== 'undefined') {
				window.UpsnapVerificationBanner.init();
			}
		});
	</script>
{% endblock %}
