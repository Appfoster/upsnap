{% extends '_layouts/cp' %}
{% import '_includes/forms' as forms %}

{% set crumbs = [
    { html: "<a href='" ~ url('upsnap') ~ "' class='thumb cp-icon'><svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 576 512' focusable='false' aria-hidden='true'><path d='M575.8 255.5c0 18-15 32.1-32 32.1l-32 0 .7 160.2c0 2.7-.2 5.4-.5 8.1l0 16.2c0 22.1-17.9 40-40 40l-16 0c-1.1 0-2.2 0-3.3-.1c-1.4 .1-2.8 .1-4.2 .1L416 512l-24 0c-22.1 0-40-17.9-40-40l0-24 0-64c0-17.7-14.3-32-32-32l-64 0c-17.7 0-32 14.3-32 32l0 64 0 24c0 22.1-17.9 40-40 40l-24 0-31.9 0c-1.5 0-3-.1-4.5-.2c-1.2 .1-2.4 .2-3.6 .2l-16 0c-22.1 0-40-17.9-40-40l0-112c0-.9 0-1.9 .1-2.8l0-69.7-32 0c-18 0-32-14-32-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 2 21 7L564.8 231.5c8 7 12 15 11 24z'></path></svg></a>" },
] %}
{% set hasApiKey = apiKey is not empty %}
	{% set isActiveApiToken = apiTokenStatus is same as(apiTokenStatuses.active) ? true : false %}

{% block actionButton %}
	{% if isActiveApiToken %}
		<div class="buttons">
			<div class="btngroup">
				<button type="button" class="btn submit add icon" data-icon="add" id="add-status-page-btn" onclick="window.location.href='{{ url('upsnap/status-page/new') }}'">
					{{ 'Add Status Page'|t('upsnap') }}
				</button>
			</div>
		</div>
	{% endif %}
{% endblock %}


{% block content %}
	<script>
		window.Upsnap = {
apiKey: {{ apiKey|json_encode|raw }},
upsnapDashboardUrl: {{ (upsnapDashboardUrl ?? 'unknown')|json_encode|raw }},
upsnapStatsPageUrl: {{ (upsnapStatsPageUrl ?? 'unknown')|json_encode|raw }},
userDetails: {{ userDetails|json_encode|raw }}
};
	</script>
	{% if not hasApiKey %}
		{# ── Case 1: Unregistered / no API key ────────────────────────────── #}
		<div class="status-container warning">
			<div class="status-header">
				<div class="status-icon warning">!</div>
				<h3 class="status-title">
					{{ 'Need to register for this feature. Your status pages will look like this once registered.'|t('upsnap') }}
				</h3>
			</div>
			<p class="status-message-dashboard">
				<a href="{{ cpUrl('upsnap/settings') }}" class="go">{{ 'Register'|t('upsnap') }}</a>
				{{ 'to activate this feature and get a public status page accessible via a shareable link.'|t('upsnap') }}
			</p>
		</div>
		<p>{{ 'Example Status Page'|t('upsnap') }}</p>
		<div class="zilch register-message">
			<img class="placeholder-image" src="{{ view.getAssetManager().getPublishedUrl( '@appfoster/upsnap/../resources/images/status-page-placeholder.png', true ) }}" alt="{{ 'Status page placeholder'|t('upsnap') }}"/>
			<img class="placeholder-image" src="{{ view.getAssetManager().getPublishedUrl( '@appfoster/upsnap/../resources/images/status-detail-page-placeholder.png', true ) }}" alt="{{ 'Status page placeholder'|t('upsnap') }}"/>
		</div>
	{% elseif hasApiKey and not isActiveApiToken %}
		{# ── Case 2 & 4: API key exists but expired / suspended / deleted ── #}
		<div class="sp-preview-table-wrapper">
			<div class="sp-preview-gate-status-page">
				<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
				</svg>
				<h3>
					{% if apiTokenStatus == apiTokenStatuses.account_expired %}
						{{ 'Your 3-day free trial has expired. Please verify your email to continue using the service. Check your inbox for the verification link sent at registration, or use the forgot-password flow to verify your account.'|t('upsnap') }}
					{% else %}
						{{ 'Your API token is expired or suspended. Update it in Settings to restore access.'|t('upsnap') }}
					{% endif %}
				</h3>
				<a href="{{ cpUrl('upsnap/settings') }}" class="btn submit sp-preview-gate-btn">{{ 'Go to Settings'|t('upsnap') }}</a>
			</div>
			<div class="zilch register-message" style="filter:blur(3px); opacity:0.5; pointer-events:none; user-select:none;">
				<img class="placeholder-image" src="{{ view.getAssetManager().getPublishedUrl( '@appfoster/upsnap/../resources/images/status-page-placeholder.png', true ) }}" alt="{{ 'Status page placeholder'|t('upsnap') }}"/>
				<img class="placeholder-image" src="{{ view.getAssetManager().getPublishedUrl( '@appfoster/upsnap/../resources/images/status-detail-page-placeholder.png', true ) }}" alt="{{ 'Status page placeholder'|t('upsnap') }}"/>
			</div>
		</div>
	{% else %}
		<div id="status-pages-wrapper">
			<div class="loader-overlay">
				<div class="spinner big" id="status-pages-loader"></div>
			</div>

			<table class="data fullwidth hidden" id="status-pages-table">
				<thead>
					<tr>
						<th>{{ 'Name'|t('upsnap') }}</th>
						<th>{{ 'Status'|t('upsnap') }}</th>
						<th class="thin">{{ 'Actions'|t('upsnap') }}</th>
					</tr>
				</thead>
				<tbody></tbody>
			</table>

			<div class="zilch hidden" id="status-pages-empty">
				<h2>{{ 'Create your first Status Page'|t('upsnap') }}</h2>
				<p>{{ 'Share real-time uptime with your users, reduce support requests, and build trust with a public or private status page.'|t('upsnap') }}</p>
			</div>
		</div>
	{% endif %}
{% endblock %}
